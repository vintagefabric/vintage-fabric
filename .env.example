# ─────────────────────────────────────────────────────────────────────────
# Vintage Fabric — environment variables
# Copy this file to `.env.local` and fill in real values.
# The site runs fully WITHOUT any of these (it falls back to local seed data
# and logs leads to the console), so you can `npm run dev` immediately.
# Add each service when you're ready to go live.
# ─────────────────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (database + admin) ──────────────────────────────────────────
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER-ONLY — never expose to the browser. Used by
# /api/leads to insert rows and by /admin to read them.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (inquiry emails) ──────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=
# Verified sender + where inquiries are delivered.
LEADS_FROM_EMAIL=inquiries@vintagefabric.in
LEADS_TO_EMAIL=vintagefabric666@gmail.com

# ── Cloudinary (images) ──────────────────────────────────────────────────
# Only the cloud name is needed for delivery URLs; uploads are done in the
# Cloudinary dashboard for now (no checkout/upload UI in Stage 1).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Admin (/admin) ───────────────────────────────────────────────────────
# Simple password gate for the leads dashboard until Supabase Auth is wired.
ADMIN_PASSWORD=change-me
